{
  "name": "notifications-platform",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build producer && nest build consumer && nest build notifier && nest build notifications-platform",
    "build:all": "nest build",
    "format": "prettier --check \"apps/**/*.ts\" \"libs/**/*.ts\" \"test/**/*.ts\"",
    "format:write": "prettier --write \"apps/**/*.ts\" \"libs/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start producer",
    "start:dev": "nest start producer --watch",
    "start:producer": "nest start producer",
    "start:producer:dev": "nest start producer --watch",
    "start:consumer": "nest start consumer",
    "start:consumer:dev": "nest start consumer --watch",
    "start:notifier": "nest start notifier",
    "start:notifier:dev": "nest start notifier --watch",
    "start:admin": "nest start notifications-platform",
    "start:admin:dev": "nest start notifications-platform --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/apps/producer/main",
    "eslint": "eslint \"{src,apps,libs,test}/**/*.ts\"",
    "lint": "npm run eslint -- --fix",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "verify:release": "npm run format && npm run eslint && npm run typecheck && npm run test -- --runInBand && npm run test:e2e -- --runInBand && npm run build"
  },
  "dependencies": {
    "@golevelup/nestjs-rabbitmq": "^9.0.0",
    "@nestjs/cache-manager": "^3.1.2",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.0.1",
    "@nestjs/microservices": "^11.1.19",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/swagger": "^11.4.2",
    "amqplib": "^1.0.6",
    "axios": "^1.16.0",
    "cache-manager": "^7.2.8",
    "cache-manager-redis-yet": "^5.1.5",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "joi": "^18.2.1",
    "nestjs-pino": "^4.6.1",
    "node-telegram-bot-api": "^0.67.0",
    "pg": "^8.20.0",
    "pino-http": "^11.0.0",
    "pino-pretty": "^13.1.3",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/amqplib": "^0.10.8",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.0.0",
    "@types/node-telegram-bot-api": "^0.64.14",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.0.0",
    "@types/uuid": "^10.0.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^17.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "moduleNameMapper": {
      "^@app/shared$": "<rootDir>/libs/shared/src/index.ts",
      "^@app/shared/(.*)$": "<rootDir>/libs/shared/src/$1",
      "^@app/rabbitmq$": "<rootDir>/libs/rabbitmq/src/index.ts",
      "^@app/rabbitmq/(.*)$": "<rootDir>/libs/rabbitmq/src/$1"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "./coverage",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/apps/",
      "<rootDir>/libs/",
      "<rootDir>/test/"
    ]
  }
}
