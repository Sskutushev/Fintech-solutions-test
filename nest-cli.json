{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "apps/notifications-platform/src",
  "compilerOptions": {
    "deleteOutDir": true,
    "webpack": true,
    "tsConfigPath": "apps/notifications-platform/tsconfig.app.json"
  },
  "monorepo": true,
  "root": "apps/notifications-platform",
  "projects": {
    "consumer": {
      "type": "application",
      "root": "apps/consumer",
      "entryFile": "main",
      "sourceRoot": "apps/consumer/src",
      "compilerOptions": {
        "tsConfigPath": "apps/consumer/tsconfig.app.json"
      }
    },
    "notifications-platform": {
      "type": "application",
      "root": "apps/notifications-platform",
      "entryFile": "main",
      "sourceRoot": "apps/notifications-platform/src",
      "compilerOptions": {
        "tsConfigPath": "apps/notifications-platform/tsconfig.app.json"
      }
    },
    "notifier": {
      "type": "application",
      "root": "apps/notifier",
      "entryFile": "main",
      "sourceRoot": "apps/notifier/src",
      "compilerOptions": {
        "tsConfigPath": "apps/notifier/tsconfig.app.json"
      }
    },
    "producer": {
      "type": "application",
      "root": "apps/producer",
      "entryFile": "main",
      "sourceRoot": "apps/producer/src",
      "compilerOptions": {
        "tsConfigPath": "apps/producer/tsconfig.app.json"
      }
    }
  }
}