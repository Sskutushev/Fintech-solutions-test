# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672
RABBITMQ_PREFETCH=10

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# PostgreSQL audit
POSTGRES_URL=postgresql://fintech:fintech@postgres:5432/fintech

# Telegram
TELEGRAM_BOT_TOKEN=replace_me
TELEGRAM_CHAT_ID=replace_me

# Service ports
PORT=3000
PRODUCER_PORT=3001
CONSUMER_PORT=3002
NOTIFIER_PORT=3003

# Admin internal URLs
PRODUCER_INTERNAL_URL=http://producer:3001
CONSUMER_INTERNAL_URL=http://consumer:3002
NOTIFIER_INTERNAL_URL=http://notifier:3003
RABBITMQ_MANAGEMENT_URL=http://rabbitmq:15672/api
RABBITMQ_DEFAULT_USER=guest
RABBITMQ_DEFAULT_PASS=guest
